# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WhatsApp contact number (digits only, no + or spaces, e.g. 971XXXXXXXXX)
VITE_WHATSAPP_NUMBER="971XXXXXXXXX"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email sender address (must be a verified domain in Resend; use onboarding@resend.dev for testing)
FROM_EMAIL="onboarding@resend.dev"

# Supabase — frontend (Vite exposes VITE_ prefixed vars to the browser bundle)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Supabase — server functions (Vercel/Express, read via process.env)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"
